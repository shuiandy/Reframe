<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 所有静态文案经 x:Uid 从 Strings\<lang>\SettingsPage.resw 取(键见各 x:Uid 末段 + .Text/.Content/.Header)。
         运行时拼装的字符串(状态行/版本号/对话框)在 code-behind 走 Loc.T。详见 docs\dev\I18N.md。 -->
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock x:Uid="/SettingsPage/Title" FontSize="28" FontWeight="SemiBold"/>

            <!-- 外观 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/AppearanceHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/AppearanceDesc" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                <ComboBox x:Name="LanguageCombo"
                          x:Uid="/SettingsPage/LanguageCombo"
                          SelectionChanged="LanguageCombo_SelectionChanged"
                          Width="240" HorizontalAlignment="Left">
                    <ComboBoxItem x:Uid="/SettingsPage/LanguageSystem"/>
                    <!-- 语言项本身用各语言自称(不随界面语言变):简体中文 / English。 -->
                    <ComboBoxItem Content="简体中文"/>
                    <ComboBoxItem Content="English"/>
                </ComboBox>
                <ComboBox x:Name="ThemeCombo"
                          x:Uid="/SettingsPage/ThemeCombo"
                          SelectionChanged="ThemeCombo_SelectionChanged"
                          Width="240" HorizontalAlignment="Left">
                    <ComboBoxItem x:Uid="/SettingsPage/ThemeSystem"/>
                    <ComboBoxItem x:Uid="/SettingsPage/ThemeLight"/>
                    <ComboBoxItem x:Uid="/SettingsPage/ThemeDark"/>
                </ComboBox>
                <ComboBox x:Name="BackdropCombo"
                          x:Uid="/SettingsPage/BackdropCombo"
                          SelectionChanged="BackdropCombo_SelectionChanged"
                          Width="240" HorizontalAlignment="Left">
                    <ComboBoxItem x:Uid="/SettingsPage/BackdropMica"/>
                    <ComboBoxItem x:Uid="/SettingsPage/BackdropMicaAlt"/>
                    <ComboBoxItem x:Uid="/SettingsPage/BackdropAcrylic"/>
                </ComboBox>
            </StackPanel>

            <!-- 在线图标(SteamGridDB) -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/SgdbHeader" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12">
                    <Run x:Uid="/SettingsPage/SgdbDescLine1"/>
                    <LineBreak/>
                    <Run x:Uid="/SettingsPage/SgdbDescApply"/>
                    <Hyperlink NavigateUri="https://www.steamgriddb.com/profile/preferences/api">https://www.steamgriddb.com/profile/preferences/api</Hyperlink>
                </TextBlock>
                <TextBox x:Name="SgdbKeyBox"
                         x:Uid="/SettingsPage/SgdbKeyBox"
                         LostFocus="SgdbKeyBox_LostFocus"
                         Width="420" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 轮询间隔 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/PollHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/PollDesc" Opacity="0.7" FontSize="12"/>
                <NumberBox x:Name="PollBox"
                           Minimum="300" Maximum="60000"
                           SmallChange="100" LargeChange="500"
                           SpinButtonPlacementMode="Inline"
                           ValueChanged="PollBox_ValueChanged"
                           Width="200" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 开机自启 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/StartupHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/StartupDesc" Opacity="0.7" FontSize="12"/>
                <!-- OnContent/OffContent 经 code-behind 用 Common/On|Off 设(ToggleSwitch 的 On/OffContent 用 x:Uid 同样走附加式较脆,改代码设)。 -->
                <ToggleSwitch x:Name="StartupToggle"
                              Toggled="StartupToggle_Toggled"/>
            </StackPanel>

            <!-- 拖拽吸附 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/DragSnapHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/DragSnapDesc" Opacity="0.7" FontSize="12"/>
                <ToggleSwitch x:Name="DragSnapToggle"
                              Toggled="DragSnapToggle_Toggled"/>
            </StackPanel>

            <!-- 还原全部 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/TakeoverHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/TakeoverDesc" Opacity="0.7" FontSize="12"/>
                <Button x:Name="RestoreAllButton" x:Uid="/SettingsPage/RestoreAllButton"
                        Click="RestoreAllButton_Click"/>
            </StackPanel>

            <!-- 热键 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/HotkeysHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/HotkeysDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="12"/>
                <!-- 每个动作一行:动作名 + 手势 TextBox,运行时按动作表填充 -->
                <StackPanel x:Name="HotkeyRows" Spacing="8"/>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="ApplyHotkeysButton" x:Uid="/SettingsPage/ApplyHotkeysButton"
                            Click="ApplyHotkeysButton_Click"/>
                    <Button x:Name="ResetHotkeysButton" x:Uid="/SettingsPage/ResetHotkeysButton"
                            Click="ResetHotkeysButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="HotkeyStatusText" TextWrapping="Wrap" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- 配置备份 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/BackupHeader" FontWeight="SemiBold"/>
                <TextBlock x:Uid="/SettingsPage/BackupDesc" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="ExportConfigButton" x:Uid="/SettingsPage/ExportConfigButton"
                            Click="ExportConfigButton_Click"/>
                    <Button x:Name="ImportConfigButton" x:Uid="/SettingsPage/ImportConfigButton"
                            Click="ImportConfigButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="BackupStatusText" TextWrapping="Wrap" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- 配置文件路径 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/ConfigFileHeader" FontWeight="SemiBold"/>
                <TextBlock x:Name="ConfigPathText" Opacity="0.7" FontSize="12"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                <Button x:Name="OpenFolderButton" x:Uid="/SettingsPage/OpenFolderButton"
                        Click="OpenFolderButton_Click"/>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="6">
                <TextBlock x:Uid="/SettingsPage/AboutHeader" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText" Opacity="0.7" FontSize="12"/>
                <TextBlock x:Uid="/SettingsPage/AboutBlurb" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
