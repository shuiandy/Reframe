<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold"/>

            <!-- 外观 -->
            <StackPanel Spacing="6">
                <TextBlock Text="外观" FontWeight="SemiBold"/>
                <TextBlock Text="主窗口的背景材质,改即生效。亚克力在窗口失焦时会回退为纯色(系统行为)。" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                <ComboBox x:Name="BackdropCombo"
                          Header="窗口背景材质"
                          SelectionChanged="BackdropCombo_SelectionChanged"
                          Width="240" HorizontalAlignment="Left">
                    <ComboBoxItem Content="云母(Mica)"/>
                    <ComboBoxItem Content="云母变体(Mica Alt)"/>
                    <ComboBoxItem Content="亚克力(毛玻璃)"/>
                </ComboBox>
            </StackPanel>

            <!-- 在线图标(SteamGridDB) -->
            <StackPanel Spacing="6">
                <TextBlock Text="在线图标(SteamGridDB)" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12">
                    <Run Text="本地取不到游戏图标(反作弊保护等)时,按游戏名联网取图标作为兜底。填入免费 API key 才启用,留空则静默关闭。"/>
                    <LineBreak/>
                    <Run Text="免费申请:"/>
                    <Hyperlink NavigateUri="https://www.steamgriddb.com/profile/preferences/api">https://www.steamgriddb.com/profile/preferences/api</Hyperlink>
                </TextBlock>
                <TextBox x:Name="SgdbKeyBox" Header="API key"
                         PlaceholderText="留空 = 关闭在线图标"
                         LostFocus="SgdbKeyBox_LostFocus"
                         Width="420" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 轮询间隔 -->
            <StackPanel Spacing="6">
                <TextBlock Text="轮询间隔" FontWeight="SemiBold"/>
                <TextBlock Text="引擎兜底扫描的周期(毫秒),越小越灵敏但越费 CPU。" Opacity="0.7" FontSize="12"/>
                <NumberBox x:Name="PollBox"
                           Minimum="300" Maximum="60000"
                           SmallChange="100" LargeChange="500"
                           SpinButtonPlacementMode="Inline"
                           ValueChanged="PollBox_ValueChanged"
                           Width="200" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 开机自启 -->
            <StackPanel Spacing="6">
                <TextBlock Text="开机自启" FontWeight="SemiBold"/>
                <TextBlock Text="以管理员权限随登录启动(计划任务,免 UAC 弹窗)。" Opacity="0.7" FontSize="12"/>
                <ToggleSwitch x:Name="StartupToggle"
                              OnContent="已开启" OffContent="已关闭"
                              Toggled="StartupToggle_Toggled"/>
            </StackPanel>

            <!-- 拖拽吸附 -->
            <StackPanel Spacing="6">
                <TextBlock Text="拖拽吸附" FontWeight="SemiBold"/>
                <TextBlock Text="按住 Shift 拖动任意窗口时显示分区覆盖层,松手把窗口吸进所在分区。" Opacity="0.7" FontSize="12"/>
                <ToggleSwitch x:Name="DragSnapToggle"
                              OnContent="已开启" OffContent="已关闭"
                              Toggled="DragSnapToggle_Toggled"/>
            </StackPanel>

            <!-- 还原全部 -->
            <StackPanel Spacing="6">
                <TextBlock Text="窗口接管" FontWeight="SemiBold"/>
                <TextBlock Text="把所有被 Reframe 改过的窗口还原为接管前的样式与位置。" Opacity="0.7" FontSize="12"/>
                <Button x:Name="RestoreAllButton" Content="还原全部已接管窗口"
                        Click="RestoreAllButton_Click"/>
            </StackPanel>

            <!-- 热键 -->
            <StackPanel Spacing="6">
                <TextBlock Text="热键" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                           Text="全局热键。手势形如 Ctrl+Alt+D、Ctrl+Shift+1(修饰符 Ctrl/Alt/Shift/Win + 字母/数字/F1-F12,大小写不限)。改完按「应用热键」生效;若某组合被别的程序或系统占用,会在下方与仪表盘日志提示,换一个即可。"/>
                <!-- 每个动作一行:中文名 + 手势 TextBox,运行时按动作表填充 -->
                <StackPanel x:Name="HotkeyRows" Spacing="8"/>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="ApplyHotkeysButton" Content="应用热键"
                            Click="ApplyHotkeysButton_Click"/>
                    <Button x:Name="ResetHotkeysButton" Content="恢复默认"
                            Click="ResetHotkeysButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="HotkeyStatusText" TextWrapping="Wrap" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- 配置备份 -->
            <StackPanel Spacing="6">
                <TextBlock Text="配置备份" FontWeight="SemiBold"/>
                <TextBlock Text="把当前配置导出为 config.json,或从文件导入(导入会校验并覆盖当前配置)。" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="ExportConfigButton" Content="导出配置…"
                            Click="ExportConfigButton_Click"/>
                    <Button x:Name="ImportConfigButton" Content="导入配置…"
                            Click="ImportConfigButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="BackupStatusText" TextWrapping="Wrap" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- 配置文件路径 -->
            <StackPanel Spacing="6">
                <TextBlock Text="配置文件" FontWeight="SemiBold"/>
                <TextBlock x:Name="ConfigPathText" Opacity="0.7" FontSize="12"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                <Button x:Name="OpenFolderButton" Content="打开所在文件夹"
                        Click="OpenFolderButton_Click"/>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="6">
                <TextBlock Text="关于" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText" Opacity="0.7" FontSize="12"/>
                <TextBlock Text="Reframe — 自用窗口管理器:无边框化 + 按显示器自适应布局。" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
