<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.ProfileEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="24,24,24,12">
            <StackPanel Spacing="20" MaxWidth="820" HorizontalAlignment="Left">

                <!-- Title -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Tooltip set from code-behind (Loc.T) — attached-property x:Uid is brittle in MRT Core. -->
                    <Button x:Name="BackButton" Click="Back_Click">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>
                    <TextBlock x:Uid="/ProfileEditorPage/Title" Style="{ThemeResource TitleTextBlockStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Basic section -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="/ProfileEditorPage/BasicHeader" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <TextBox x:Name="NameBox" x:Uid="/ProfileEditorPage/NameBox" Width="360"
                             HorizontalAlignment="Left"
                             TextChanged="NameBox_TextChanged"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="MatchKindBox" x:Uid="/ProfileEditorPage/MatchKindBox" Width="200"
                                  SelectionChanged="MatchKindBox_SelectionChanged">
                            <ComboBoxItem x:Uid="/ProfileEditorPage/MatchKindProcess"/>
                            <ComboBoxItem x:Uid="/ProfileEditorPage/MatchKindTitle"/>
                            <ComboBoxItem x:Uid="/ProfileEditorPage/MatchKindTitleRegex"/>
                        </ComboBox>
                        <TextBox x:Name="MatchValueBox" x:Uid="/ProfileEditorPage/MatchValueBox" Width="360"
                                 TextChanged="MatchValueBox_TextChanged"/>
                    </StackPanel>

                    <!-- Executable (icon source): manually specified when an anti-cheat game's MainModule can't be read; IconCache extracts the icon straight from this exe. -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
                        <TextBox x:Name="ExePathBox" x:Uid="/ProfileEditorPage/ExePathBox" Width="480"
                                 TextChanged="ExePathBox_TextChanged"/>
                        <Button x:Name="BrowseExeButton" x:Uid="/ProfileEditorPage/BrowseExeButton" Click="BrowseExe_Click"
                                VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock x:Uid="/ProfileEditorPage/ExePathHint"
                               Opacity="0.6" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>

                    <!-- Launch command (optional): for one-click launch. Empty = run the executable directly; can be a launcher command or URI (e.g. hoyoplay://). -->
                    <TextBox x:Name="LaunchCommandBox" x:Uid="/ProfileEditorPage/LaunchCommandBox" Width="480"
                             HorizontalAlignment="Left"
                             TextChanged="LaunchCommandBox_TextChanged"/>
                </StackPanel>

                <!-- Startup resolution preset (Unity). ToggleSwitch On/OffContent are set from code-behind (Common/On|Off) — see note in code-behind. -->
                <Expander x:Name="ResolutionExpander" x:Uid="/ProfileEditorPage/ResolutionExpander" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="12" Padding="0,8,0,0">
                        <TextBlock x:Uid="/ProfileEditorPage/ResolutionDesc"
                                   Opacity="0.7" TextWrapping="Wrap"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                        <ToggleSwitch x:Name="ResEnabledToggle" x:Uid="/ProfileEditorPage/ResEnabledToggle"
                                      Toggled="ResEnabled_Toggled"/>
                        <TextBox x:Name="ResPathBox" x:Uid="/ProfileEditorPage/ResPathBox" Width="420"
                                 HorizontalAlignment="Left"
                                 TextChanged="ResPath_TextChanged"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <NumberBox x:Name="ResWidthBox" x:Uid="/ProfileEditorPage/ResWidthBox" Width="160"
                                       Minimum="0" Maximum="32768" SmallChange="1" LargeChange="100"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="ResSize_ValueChanged"/>
                            <NumberBox x:Name="ResHeightBox" x:Uid="/ProfileEditorPage/ResHeightBox" Width="160"
                                       Minimum="0" Maximum="32768" SmallChange="1" LargeChange="100"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="ResSize_ValueChanged"/>
                        </StackPanel>
                        <CheckBox x:Name="ResWindowedCheck" x:Uid="/ProfileEditorPage/ResWindowedCheck"
                                  Checked="ResWindowed_Changed" Unchecked="ResWindowed_Changed"/>
                    </StackPanel>
                </Expander>

                <!-- Borderless section -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="/ProfileEditorPage/BorderlessHeader" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="BorderlessToggle" x:Uid="/ProfileEditorPage/BorderlessToggle"
                                  Toggled="BorderlessToggle_Toggled"/>
                    <NumberBox x:Name="DelayBox" x:Uid="/ProfileEditorPage/DelayBox" Width="240"
                               HorizontalAlignment="Left"
                               Minimum="0" Maximum="60000" SmallChange="100" LargeChange="500"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="DelayBox_ValueChanged"/>
                </StackPanel>

                <!-- Rules list -->
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Uid="/ProfileEditorPage/RulesHeader" Style="{ThemeResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Uid="/ProfileEditorPage/RulesHint"
                                   Opacity="0.6" VerticalAlignment="Center"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                    </StackPanel>

                    <StackPanel x:Name="RulesPanel" Spacing="12"/>

                    <Button Click="AddRule_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock x:Uid="/ProfileEditorPage/AddRuleButton"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Advanced section. ToggleSwitch On/OffContent are set from code-behind (Common/On|Off). -->
                <Expander x:Name="AdvancedExpander" x:Uid="/ProfileEditorPage/AdvancedExpander" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="16" Padding="0,8,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="/ProfileEditorPage/OffsetsHeader" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="/ProfileEditorPage/OffsetsDesc" Opacity="0.6"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <NumberBox x:Name="OffLeftBox" x:Uid="/ProfileEditorPage/OffLeftBox" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffTopBox" x:Uid="/ProfileEditorPage/OffTopBox" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffRightBox" x:Uid="/ProfileEditorPage/OffRightBox" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffBottomBox" x:Uid="/ProfileEditorPage/OffBottomBox" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="/ProfileEditorPage/ExtraBehaviorHeader" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <ToggleSwitch x:Name="TopmostToggle" x:Uid="/ProfileEditorPage/TopmostToggle"
                                          Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="AspectToggle" x:Uid="/ProfileEditorPage/AspectToggle"
                                          Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="MuteToggle" x:Uid="/ProfileEditorPage/MuteToggle"
                                          Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="ClipToggle" x:Uid="/ProfileEditorPage/ClipToggle"
                                          Toggled="M3Toggle_Toggled"/>
                            <!-- The only toggle the engine doesn't consume yet: persisted faithfully, but currently has no effect. -->
                            <ToggleSwitch x:Name="ClientToggle" x:Uid="/ProfileEditorPage/ClientToggle"
                                          Toggled="M3Toggle_Toggled"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock x:Name="MissingHint" x:Uid="/ProfileEditorPage/MissingHint"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <Button x:Name="CancelButton" x:Uid="/ProfileEditorPage/CancelButton" Click="Cancel_Click"/>
                <Button x:Name="SaveButton" x:Uid="/ProfileEditorPage/SaveButton" Style="{ThemeResource AccentButtonStyle}"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
