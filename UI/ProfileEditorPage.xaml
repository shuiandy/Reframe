<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.ProfileEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="24,24,24,12">
            <StackPanel Spacing="20" MaxWidth="820" HorizontalAlignment="Left">

                <!-- 标题 -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Click="Back_Click" ToolTipService.ToolTip="返回">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>
                    <TextBlock Text="编辑配置文件" Style="{ThemeResource TitleTextBlockStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 基本区 -->
                <StackPanel Spacing="12">
                    <TextBlock Text="基本" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <TextBox x:Name="NameBox" Header="名称" Width="360"
                             HorizontalAlignment="Left"
                             TextChanged="NameBox_TextChanged"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="MatchKindBox" Header="匹配类型" Width="200"
                                  SelectionChanged="MatchKindBox_SelectionChanged">
                            <ComboBoxItem Content="进程名"/>
                            <ComboBoxItem Content="窗口标题(包含)"/>
                            <ComboBoxItem Content="标题正则"/>
                        </ComboBox>
                        <TextBox x:Name="MatchValueBox" Header="匹配文本" Width="360"
                                 TextChanged="MatchValueBox_TextChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- 启动分辨率预设(Unity) -->
                <Expander x:Name="ResolutionExpander" Header="启动分辨率预设 (Unity)" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="12" Padding="0,8,0,0">
                        <TextBlock Text="适用于渲染分辨率钉死在注册表的 Unity 游戏(如原神)。启动游戏前生效;游戏运行中修改无效。"
                                   Opacity="0.7" TextWrapping="Wrap"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                        <ToggleSwitch x:Name="ResEnabledToggle" Header="启用启动分辨率预设"
                                      OnContent="开" OffContent="关" Toggled="ResEnabled_Toggled"/>
                        <TextBox x:Name="ResPathBox" Header="注册表路径 (HKCU 下相对路径)" Width="420"
                                 HorizontalAlignment="Left"
                                 PlaceholderText="Software\miHoYo\原神"
                                 TextChanged="ResPath_TextChanged"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <NumberBox x:Name="ResWidthBox" Header="宽" Width="160"
                                       Minimum="0" Maximum="32768" SmallChange="1" LargeChange="100"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="ResSize_ValueChanged"/>
                            <NumberBox x:Name="ResHeightBox" Header="高" Width="160"
                                       Minimum="0" Maximum="32768" SmallChange="1" LargeChange="100"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="ResSize_ValueChanged"/>
                        </StackPanel>
                        <CheckBox x:Name="ResWindowedCheck" Content="窗口化 (Is Fullscreen mode = 0)"
                                  Checked="ResWindowed_Changed" Unchecked="ResWindowed_Changed"/>
                    </StackPanel>
                </Expander>

                <!-- 无边框区 -->
                <StackPanel Spacing="12">
                    <TextBlock Text="无边框" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="BorderlessToggle" Header="去除窗口边框"
                                  OnContent="开启" OffContent="关闭"
                                  Toggled="BorderlessToggle_Toggled"/>
                    <NumberBox x:Name="DelayBox" Header="处理延迟 (毫秒)" Width="240"
                               HorizontalAlignment="Left"
                               Minimum="0" Maximum="60000" SmallChange="100" LargeChange="500"
                               SpinButtonPlacementMode="Compact"
                               Description="游戏启动期会重建窗口,建议 1000"
                               ValueChanged="DelayBox_ValueChanged"/>
                </StackPanel>

                <!-- 规则表 -->
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="规则" Style="{ThemeResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="(自上而下,第一条命中当前显示器的规则生效)"
                                   Opacity="0.6" VerticalAlignment="Center"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                    </StackPanel>

                    <StackPanel x:Name="RulesPanel" Spacing="12"/>

                    <Button Click="AddRule_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="添加规则"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 高级区 -->
                <Expander x:Name="AdvancedExpander" Header="高级" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="16" Padding="0,8,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="四边偏移 (像素)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="施加在最终矩形上的微调。" Opacity="0.6"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <NumberBox x:Name="OffLeftBox" Header="左" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffTopBox" Header="上" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffRightBox" Header="右" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                                <NumberBox x:Name="OffBottomBox" Header="下" Width="120"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="Offset_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="附加行为 (即将支持)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="以下开关会如实保存,但当前引擎版本暂不消费。" Opacity="0.6"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <ToggleSwitch x:Name="TopmostToggle" Header="始终置顶"
                                          OnContent="开" OffContent="关" Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="AspectToggle" Header="保持宽高比"
                                          OnContent="开" OffContent="关" Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="ClientToggle" Header="保持客户区大小"
                                          OnContent="开" OffContent="关" Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="MuteToggle" Header="后台静音"
                                          OnContent="开" OffContent="关" Toggled="M3Toggle_Toggled"/>
                            <ToggleSwitch x:Name="ClipToggle" Header="光标限制在窗口内"
                                          OnContent="开" OffContent="关" Toggled="M3Toggle_Toggled"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock x:Name="MissingHint" Text="未找到该配置文件。"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <Button x:Name="CancelButton" Content="取消" Click="Cancel_Click"/>
                <Button x:Name="SaveButton" Content="保存" Style="{ThemeResource AccentButtonStyle}"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
