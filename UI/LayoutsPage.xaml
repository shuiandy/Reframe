<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.LayoutsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ctrl="using:Reframe.UI.Controls"
    xmlns:local="using:Reframe.UI"
    mc:Ignorable="d">

    <Grid Margin="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="布局" Style="{ThemeResource TitleTextBlockStyle}"/>

        <CommandBar Grid.Row="1"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left"
                    Background="Transparent">
            <AppBarButton x:Name="NewButton" Icon="Add" Label="新建" Click="NewButton_Click"/>
            <AppBarButton x:Name="DuplicateButton" Icon="Copy" Label="复制" Click="DuplicateButton_Click"/>
            <AppBarButton x:Name="EditButton" Icon="Edit" Label="编辑" Click="EditButton_Click"/>
            <AppBarButton x:Name="DeleteButton" Icon="Delete" Label="删除" Click="DeleteButton_Click"/>
        </CommandBar>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <GridView x:Name="LayoutsGrid"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="LayoutsGrid_ItemClick"
                          SelectionChanged="LayoutsGrid_SelectionChanged">
                    <!-- 卡片 hover:由系统 GridViewItem 容器驱动(无自定义动画)。
                         容器圆角对齐内卡;pointer-over 用内置状态切换边框/背景刷,
                         本地把这些刷改成 accent 描边 + 微抬升的层色。 -->
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="UseSystemFocusVisuals" Value="True"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.Resources>
                        <!-- pointer-over:边框转 accent、背景轻提亮(均为内置 ThemeResource) -->
                        <StaticResource x:Key="GridViewItemBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush"/>
                        <StaticResource x:Key="GridViewItemBorderBrushPointerOver" ResourceKey="AccentFillColorDefaultBrush"/>
                        <!-- 选中态也用 accent 描边,与 hover 呼应 -->
                        <StaticResource x:Key="GridViewItemBorderBrushSelected" ResourceKey="AccentFillColorDefaultBrush"/>
                        <StaticResource x:Key="GridViewItemBorderBrushSelectedPointerOver" ResourceKey="AccentFillColorDefaultBrush"/>
                    </GridView.Resources>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:LayoutItem">
                            <!-- 卡背景刷成卡色;hover 抬升由外层容器边框/背景体现。
                                 内卡边框透明,让容器的 accent 描边成为唯一边线,避免双线。 -->
                            <Grid Width="220" Height="180" Padding="10" RowSpacing="6"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  CornerRadius="7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ctrl:LayoutPreview Grid.Row="0" Layout="{x:Bind Model}"/>
                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind Model.Name}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="2"
                                           Text="{x:Bind SummaryText}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <StackPanel x:Name="EmptyHint"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Visibility="Collapsed">
                    <FontIcon Glyph="&#xE80A;" FontSize="40"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="还没有布局,点击「新建」创建第一个。"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
