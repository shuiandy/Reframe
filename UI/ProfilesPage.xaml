<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="配置文件" Style="{ThemeResource TitleTextBlockStyle}"/>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                    Background="Transparent" HorizontalAlignment="Left"
                    IsOpen="False">
            <AppBarButton x:Name="NewButton" Icon="Add" Label="新建" Click="NewButton_Click"/>
            <AppBarButton x:Name="FromWindowButton" Label="从窗口创建" Click="FromWindowButton_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A7;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="EditButton" Icon="Edit" Label="编辑"
                          Click="EditButton_Click" IsEnabled="False"/>
            <AppBarButton x:Name="DeleteButton" Icon="Delete" Label="删除"
                          Click="DeleteButton_Click" IsEnabled="False"/>
        </CommandBar>

        <ListView x:Name="ProfileList" Grid.Row="2"
                  SelectionMode="Single"
                  IsItemClickEnabled="False"
                  DoubleTapped="ProfileList_DoubleTapped"
                  SelectionChanged="ProfileList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="12,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ProfileRow">
                    <Grid ColumnSpacing="16" Background="Transparent"
                          ContextRequested="ProfileRow_ContextRequested">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="编辑" Click="EditButton_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Edit"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="删除" Click="DeleteButton_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Delete"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ToggleSwitch Grid.Column="0"
                                      VerticalAlignment="Center"
                                      MinWidth="0"
                                      OnContent="" OffContent=""
                                      IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                      Toggled="EnabledToggle_Toggled"
                                      Tag="{x:Bind ProfileId}"/>

                        <!-- 行首图标:进程匹配显示其图标,取不到/非进程匹配回落默认字形(显隐互斥) -->
                        <Grid Grid.Column="1" Width="24" Height="24" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7FC;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="18" Opacity="0.6"
                                      Visibility="{x:Bind FallbackIconVisibility, Mode=OneWay}"/>
                            <Image Source="{x:Bind Icon, Mode=OneWay}" Width="24" Height="24"
                                   Visibility="{x:Bind RealIconVisibility, Mode=OneWay}"/>
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind MatchSummary}" Opacity="0.7"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                   Text="{x:Bind RulesSummary}" Opacity="0.7"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyHint" Grid.Row="2"
                   Text="还没有配置文件,点击上方“新建”创建一个。"
                   Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Page>
