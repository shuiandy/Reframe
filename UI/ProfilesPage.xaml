<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="/ProfilesPage/Title" Style="{ThemeResource TitleTextBlockStyle}"/>

        <!-- Home-style two-column layout: left = running windows (always present), a 1px divider in the middle, right = profile list. -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left column: running windows ===== -->
            <Grid Grid.Column="0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Uid="/ProfilesPage/RunningWindowsHeader" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <!-- Search + show-filtered + refresh -->
                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" x:Uid="/ProfilesPage/SearchBox" Grid.Column="0"
                             TextChanged="SearchBox_TextChanged"/>
                    <!-- Show filtered: when on, windows that were filtered out are also listed (greyed + reason), a fallback for recovering games that were filtered by mistake. -->
                    <!-- Tooltip is set from code-behind (Loc.T) because attached-property x:Uid is brittle in MRT Core. -->
                    <ToggleButton x:Name="ShowFilteredToggle" Grid.Column="1"
                                  VerticalAlignment="Stretch"
                                  Checked="ShowFilteredToggle_Toggled"
                                  Unchecked="ShowFilteredToggle_Toggled">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7B3;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"/>
                            <TextBlock x:Uid="/ProfilesPage/ShowFilteredLabel"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button x:Name="RefreshButton" Grid.Column="2"
                            Click="RefreshButton_Click">
                        <FontIcon Glyph="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                    </Button>
                </Grid>

                <ListView x:Name="WindowList" Grid.Row="2"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:WindowRow">
                            <!-- A filtered row is greyed out as a whole (RowOpacity); the "+ create profile" button stays usable regardless of IsFiltered (fallback). -->
                            <Grid ColumnSpacing="12" Background="Transparent"
                                  Opacity="{x:Bind RowOpacity, Mode=OneWay}">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuCreateProfile" Click="CreateProfile_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Add"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuQuickBorderless" Click="QuickBorderless_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE740;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <!-- Ignore this process (adds it to the user ignore list; disappears in normal mode); system-shell windows can't be ignored, so this item auto-hides. -->
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuIgnoreProcess" Click="IgnoreProcess_Click"
                                                        Visibility="{x:Bind IgnoreItemVisibility, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xED1A;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <!-- Stop ignoring (removes it from the list); shown only for rows the user has ignored. -->
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuUnignoreProcess" Click="UnignoreProcess_Click"
                                                        Visibility="{x:Bind UnignoreItemVisibility, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE7B3;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="32" Height="32" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xECAA;"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                              FontSize="24" Opacity="0.6"
                                              Visibility="{x:Bind FallbackIconVisibility, Mode=OneWay}"/>
                                    <Image Source="{x:Bind Icon, Mode=OneWay}" Width="32" Height="32"
                                           Visibility="{x:Bind RealIconVisibility, Mode=OneWay}"/>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}" TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind PathLabel, Mode=OneWay}" Opacity="0.7"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind SizeLabel, Mode=OneWay}" Opacity="0.7"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock x:Uid="/ProfilesPage/HasProfileTag" Opacity="0.55"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Visibility="{x:Bind HasProfileVisibility, Mode=OneWay}"/>
                                        <!-- Filter-reason caption: System window / Ignored / Hidden / Too small. -->
                                        <Border Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                                CornerRadius="4" Padding="6,1"
                                                Visibility="{x:Bind ReasonVisibility, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind ReasonLabel, Mode=OneWay}" Opacity="0.85"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tooltip set from code-behind (Loc.T via Loaded) — attached-property x:Uid is brittle in MRT Core, and named elements aren't reachable inside a DataTemplate. -->
                                <Button Grid.Column="3" VerticalAlignment="Center" Padding="9,7"
                                        Click="CreateProfile_Click"
                                        Loaded="CreateFromWindowButton_Loaded">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock x:Name="WindowEmptyHint" x:Uid="/ProfilesPage/WindowEmptyHint" Grid.Row="2"
                           Opacity="0.6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Middle divider -->
            <Border Grid.Column="1" Width="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

            <!-- ===== Right column: profile list ===== -->
            <Grid Grid.Column="2" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Uid="/ProfilesPage/ProfileListHeader" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                            Background="Transparent" HorizontalAlignment="Left"
                            IsOpen="False">
                    <AppBarButton x:Name="NewButton" x:Uid="/ProfilesPage/NewButton" Icon="Add" Click="NewButton_Click"/>
                    <AppBarButton x:Name="EditButton" x:Uid="/ProfilesPage/EditButton" Icon="Edit"
                                  Click="EditButton_Click" IsEnabled="False"/>
                    <AppBarButton x:Name="DeleteButton" x:Uid="/ProfilesPage/DeleteButton" Icon="Delete"
                                  Click="DeleteButton_Click" IsEnabled="False"/>
                </CommandBar>

                <ListView x:Name="ProfileList" Grid.Row="2"
                          SelectionMode="Single"
                          IsItemClickEnabled="False"
                          DoubleTapped="ProfileList_DoubleTapped"
                          SelectionChanged="ProfileList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ProfileRow">
                            <Grid ColumnSpacing="8" Background="Transparent"
                                  ContextRequested="ProfileRow_ContextRequested">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuEdit" Click="EditButton_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Edit"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem x:Uid="/ProfilesPage/MenuDelete" Click="DeleteButton_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Delete"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ToggleSwitch Grid.Column="0"
                                              VerticalAlignment="Center"
                                              MinWidth="0"
                                              OnContent="" OffContent=""
                                              IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                              Toggled="EnabledToggle_Toggled"
                                              Tag="{x:Bind ProfileId}"/>

                                <!-- Leading icon: a process match shows its icon; missing icon / non-process match falls back to the default glyph (visibility is mutually exclusive). -->
                                <Grid Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7FC;"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                              FontSize="24" Opacity="0.6"
                                              Visibility="{x:Bind FallbackIconVisibility, Mode=OneWay}"/>
                                    <Image Source="{x:Bind Icon, Mode=OneWay}" Width="32" Height="32"
                                           Visibility="{x:Bind RealIconVisibility, Mode=OneWay}"/>
                                </Grid>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind MatchSummary}" Opacity="0.7"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind RulesSummary}" Opacity="0.55"
                                               TextWrapping="NoWrap"
                                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>

                                <!-- Tooltip set from code-behind (Loc.T via Loaded) — see note on the left-column "+" button. -->
                                <Button Grid.Column="3" VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Padding="8"
                                        IsEnabled="{x:Bind CanLaunch}"
                                        Tag="{x:Bind ProfileId}"
                                        Click="LaunchButton_Click"
                                        Loaded="LaunchButton_Loaded">
                                    <FontIcon Glyph="&#xE768;" FontSize="16"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock x:Name="EmptyHint" x:Uid="/ProfilesPage/EmptyHint" Grid.Row="2"
                           Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
