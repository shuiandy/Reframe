<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:controls="using:Reframe.UI.Controls">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + engine master switch: title at left, engine label + toggle at right, centered on one row -->
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Uid="/DashboardPage/Title" FontSize="28" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center">
                <TextBlock x:Uid="/DashboardPage/EngineLabel" VerticalAlignment="Center"/>
                <!-- On/OffContent are set in code-behind (Loc.T); x:Uid for those attached contents is unreliable in MRT Core. -->
                <ToggleSwitch x:Name="EngineToggle"
                              VerticalAlignment="Center"
                              Loaded="EngineToggle_Loaded"
                              Toggled="EngineToggle_Toggled"/>
            </StackPanel>
        </Grid>

        <!-- Summary row -->
        <TextBlock x:Name="SummaryText" Grid.Row="1" Opacity="0.7"/>

        <!-- Live monitor mini-map (primary visual). Height auto-fits the desktop bounding-box aspect (clamped 90..320), no longer fixed at 260. -->
        <controls:LiveMonitorMap x:Name="MonitorMap" Grid.Row="2"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Top"/>

        <!-- Bottom split: left = taken-window cards, right = log (narrow) -->
        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Active windows -->
            <Grid Grid.Column="0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="/DashboardPage/TakenHeader" FontWeight="SemiBold"/>
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TakenList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:TakenCard">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="12,10" Margin="0,0,0,8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Window icon: falls back to a default glyph when unavailable (visibility is mutually exclusive) -->
                                            <Grid Grid.Column="0" Width="32" Height="32"
                                                  VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE737;"
                                                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                          FontSize="22" Opacity="0.6"
                                                          Visibility="{Binding FallbackIconVisibility, Mode=OneWay}"/>
                                                <Image Source="{Binding Icon, Mode=OneWay}"
                                                       Width="32" Height="32"
                                                       Visibility="{Binding RealIconVisibility, Mode=OneWay}"/>
                                            </Grid>

                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding ProfileName, Mode=OneWay}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SubInfo, Mode=OneWay}" Opacity="0.85"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding RectText, Mode=OneWay}" Opacity="0.6"
                                                           FontSize="12"
                                                           FontFamily="Consolas"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        Spacing="8" VerticalAlignment="Center">
                                                <Button x:Uid="/DashboardPage/RestoreButton" Tag="{Binding Handle}"
                                                        Click="RestoreWindow_Click"/>
                                                <Button x:Uid="/DashboardPage/RescanButton"
                                                        Click="Reapply_Click"
                                                        Loaded="RescanButton_Loaded"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock x:Name="TakenEmpty" x:Uid="/DashboardPage/TakenEmptyLabel"
                               Opacity="0.5" VerticalAlignment="Top" Margin="2,4"/>
                </Grid>
            </Grid>

            <!-- Log (narrow, ~5 scrollable rows) -->
            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock x:Uid="/DashboardPage/LogHeader" FontWeight="SemiBold"/>
                <ListView x:Name="LogList" SelectionMode="None" IsItemClickEnabled="False"
                          MaxHeight="160"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1" CornerRadius="6"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
