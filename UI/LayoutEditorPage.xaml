<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Reframe.UI.LayoutEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="20,12,20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title row -->
        <TextBlock Grid.Row="0" x:Uid="/LayoutEditorPage/Title" Style="{ThemeResource TitleTextBlockStyle}"/>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock x:Uid="/LayoutEditorPage/NameLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox x:Name="NameBox" Width="220" TextChanged="NameBox_TextChanged"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock x:Uid="/LayoutEditorPage/RefResLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <ComboBox x:Name="MonitorCombo" Width="240"
                              x:Uid="/LayoutEditorPage/MonitorCombo"
                              SelectionChanged="MonitorCombo_SelectionChanged"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock x:Uid="/LayoutEditorPage/WidthLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <NumberBox x:Name="RefWidthBox" Width="110"
                               SpinButtonPlacementMode="Compact" Minimum="1" Maximum="61440"
                               ValueChanged="RefSize_ValueChanged"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock x:Uid="/LayoutEditorPage/HeightLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <NumberBox x:Name="RefHeightBox" Width="110"
                               SpinButtonPlacementMode="Compact" Minimum="1" Maximum="34560"
                               ValueChanged="RefSize_ValueChanged"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Uid="/LayoutEditorPage/PresetLabel" VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}"/>
                <Button x:Uid="/LayoutEditorPage/PresetHalf" Tag="half" Click="Preset_Click"/>
                <Button x:Uid="/LayoutEditorPage/PresetThirds" Tag="thirds" Click="Preset_Click"/>
                <Button x:Uid="/LayoutEditorPage/PresetTwoThirds" Tag="twoThirds" Click="Preset_Click"/>
                <Button x:Uid="/LayoutEditorPage/PresetCenter169" Tag="center169" Click="Preset_Click"/>
                <Button x:Uid="/LayoutEditorPage/PresetLeft219" Tag="left219" Click="Preset_Click"/>
                <AppBarSeparator/>
                <Button x:Uid="/LayoutEditorPage/AddZoneButton" Click="AddZone_Click">
                    <ToolTipService.ToolTip>
                        <TextBlock x:Uid="/LayoutEditorPage/AddZoneTip"/>
                    </ToolTipService.ToolTip>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Body: canvas on the left + property panel on the right -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas host: fills the available width; the canvas height follows the reference aspect
                 ratio and the host shrinks to fit -->
            <Border Grid.Column="0"
                    x:Name="CanvasHost"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    VerticalAlignment="Top"
                    SizeChanged="CanvasHost_SizeChanged">
                <!-- Canvas: background frame + zone layer + alignment-guide layer. Its size is set from
                     code based on the available width and the aspect ratio. -->
                <!-- Intentional: the canvas backdrop stays dark (#101418) because it simulates the
                     physical screen, which is black; it must not turn white under the light theme,
                     which would mislead the user about the area they are placing. The border is
                     container chrome rather than screen content, so it uses a ThemeResource to adapt. -->
                <Border x:Name="CanvasFrame"
                        HorizontalAlignment="Center"
                        Background="#101418"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Canvas x:Name="ZoneCanvas">
                        <Canvas x:Name="GuideCanvas" IsHitTestVisible="False"/>
                    </Canvas>
                </Border>
            </Border>

            <!-- Property panel -->
            <Border Grid.Column="1" Width="280"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="/LayoutEditorPage/PropHeader" Style="{ThemeResource BodyStrongTextBlockStyle}"/>

                    <StackPanel x:Name="PropPanel" Spacing="10" Visibility="Collapsed">
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="/LayoutEditorPage/ZoneNameLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <TextBox x:Name="ZoneNameBox" TextChanged="ZoneNameBox_TextChanged"/>
                        </StackPanel>
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                <TextBlock x:Uid="/LayoutEditorPage/ZoneXLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <NumberBox x:Name="ZoneXBox" Minimum="0" ValueChanged="ZonePx_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                <TextBlock x:Uid="/LayoutEditorPage/ZoneYLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <NumberBox x:Name="ZoneYBox" Minimum="0" ValueChanged="ZonePx_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                <TextBlock x:Uid="/LayoutEditorPage/ZoneWLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <NumberBox x:Name="ZoneWBox" Minimum="1" ValueChanged="ZonePx_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                <TextBlock x:Uid="/LayoutEditorPage/ZoneHLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <NumberBox x:Name="ZoneHBox" Minimum="1" ValueChanged="ZonePx_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="ZoneRatioText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button x:Uid="/LayoutEditorPage/DeleteZoneButton" Click="DeleteZone_Click">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <StaticResource x:Key="ButtonForeground" ResourceKey="SystemFillColorCriticalBrush"/>
                                </ResourceDictionary>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="NoSelHint"
                               x:Uid="/LayoutEditorPage/NoSelHint"
                               TextWrapping="Wrap"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Uid="/LayoutEditorPage/CancelButton" Click="Cancel_Click"/>
            <Button x:Uid="/LayoutEditorPage/SaveButton" Style="{ThemeResource AccentButtonStyle}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Page>
