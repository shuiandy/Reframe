<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Reframe.UI.RegionPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:Reframe.UI.Controls">

    <ctrl:CursorGrid x:Name="Root"
          Background="#01000000"
          IsTabStop="True"
          PointerPressed="Root_PointerPressed"
          PointerMoved="Root_PointerMoved"
          PointerReleased="Root_PointerReleased"
          RightTapped="Root_RightTapped">

        <!-- 深色遮罩 -->
        <Grid Background="#80000000"/>

        <!-- 选区:用 Canvas 放一个亮边框矩形 + 尺寸徽标 -->
        <Canvas x:Name="OverlayCanvas">
            <Rectangle x:Name="SelectionRect"
                       Visibility="Collapsed"
                       Stroke="#FF4FC3F7"
                       StrokeThickness="2"
                       Fill="#204FC3F7"/>
            <Border x:Name="SizeBadge"
                    Visibility="Collapsed"
                    Background="#CC101418"
                    BorderBrush="#FF4FC3F7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,4">
                <TextBlock x:Name="SizeText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>

        <!-- 提示语 -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Background="#B0101418"
                CornerRadius="6"
                Padding="14,8">
            <TextBlock Foreground="#E0FFFFFF" FontSize="13"
                       Text="拖拽框选区域 · 松开确认 · Esc 或右键取消"/>
        </Border>
    </ctrl:CursorGrid>
</Window>
