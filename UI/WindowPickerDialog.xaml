<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Reframe.UI.WindowPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reframe.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="从运行中的窗口创建"
    PrimaryButtonText="创建"
    CloseButtonText="取消"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    PrimaryButtonClick="OnCreateClick">

    <Grid Width="520" Height="440" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     PlaceholderText="按标题或进程名筛选…"
                     TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="RefreshButton" Grid.Column="1"
                    Click="RefreshButton_Click" ToolTipService.ToolTip="刷新窗口列表">
                <FontIcon Glyph="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
            </Button>
        </Grid>

        <ListView x:Name="WindowList" Grid.Row="1"
                  SelectionMode="Single"
                  SelectionChanged="WindowList_SelectionChanged"
                  ScrollViewer.HorizontalScrollMode="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="12,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:WindowRow">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xECAA;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="18" Opacity="0.6"
                                      Visibility="{x:Bind FallbackIconVisibility}"/>
                            <Image Source="{x:Bind Icon}" Width="24" Height="24"
                                   Visibility="{x:Bind RealIconVisibility}"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ProcessLabel}" Opacity="0.7"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                   Text="{x:Bind SizeLabel}" Opacity="0.7"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyHint" Grid.Row="1"
                   Text="没有可选的窗口。" Opacity="0.6"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <TextBlock Grid.Row="2" Opacity="0.6"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Text="创建后会跳到规则编辑页,可继续调整布局规则。"/>
    </Grid>
</ContentDialog>
