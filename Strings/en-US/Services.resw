  <data name="BackupFileTypeLabel" xml:space="preserve">
    <value>Reframe configuration</value>
  </data>
  <data name="ImportInvalidTitle" xml:space="preserve">
    <value>Import failed</value>
  </data>
  <data name="ImportInvalidContent" xml:space="preserve">
    <value>Invalid file: not a valid Reframe configuration file.</value>
  </data>
</root>
