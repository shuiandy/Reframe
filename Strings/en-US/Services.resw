  </data>
  <data name="LaunchFileNotFoundFormat" xml:space="preserve">
    <value>File not found: {0}</value>
  </data>
  <data name="LaunchFailedFormat" xml:space="preserve">
    <value>Launch failed: {0}</value>
  </data>
  <data name="LaunchUnnamedProfile" xml:space="preserve">
    <value>This profile</value>
  </data>

