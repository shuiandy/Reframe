    <value>System.Resources.ResXResourceWriter, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value>
  </resheader>

  <!-- Top operation hint -->
  <data name="Hint.Text" xml:space="preserve">
    <value>Drag to select a region · release to confirm · Esc or right-click to cancel</value>
  </data>

  <!-- ===== Code-behind dynamic strings ===== -->
  <!-- Selection size badge: {0}=physical-pixel width, {1}=physical-pixel height -->
  <data name="SizeBadgeFormat" xml:space="preserve">
    <value>{0} × {1} px</value>
