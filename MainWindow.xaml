<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Reframe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Reframe">

    <!-- 真两行布局(图吧工具箱式),取代旧的"标题栏覆盖条浮在 NavigationView 之上"方案。
         旧方案在侧栏收起时结构性撞车:内容区左移,页面大标题钻进浮在顶上的标题栏带与"Reframe"重叠。
         现在 Row0 是实体标题栏占据真实高度,Row1 才是 NavigationView —— 页面内容永远从 Row1 起,
         无论侧栏展开/收起/窗口多窄都不可能钻到标题栏底下。
         ExtendsContentIntoTitleBar=true + SetTitleBar(AppTitleDragRegion) 在代码后置里设。 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0:实体标题栏。三列 Auto(自绘汉堡) / Auto(图标+标题) / *(拖拽区,延伸到右侧系统按钮处)。
             自绘汉堡必须在拖拽区(SetTitleBar 元素)之外 —— SetTitleBar 元素内的交互控件收不到输入。
             图标+标题是非交互元素,放哪都不挡;此处放拖拽区内,随手可拖更顺手。 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 自绘汉堡:替代 NavigationView 自带 PaneToggleButton(已隐藏)。
                 尺寸/观感对齐原生:约 40 宽 36 高、透明底、hover 有底色(借 SubtleFillColorSecondaryBrush /
                 pressed 用 Tertiary,与系统 Subtle 按钮一致)、垂直居中。FontIcon E700 = GlobalNavigationButton。
                 在拖拽区之外,故 Click 能正常收到。 -->
            <Button x:Name="PaneToggleButton"
                    Grid.Column="0"
                    Width="40" Height="36"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    AutomationProperties.Name="导航"
                    ToolTipService.ToolTip="导航"
                    Click="PaneToggle_Click">
                <FontIcon Glyph="&#xE700;" FontSize="16"/>
            </Button>

            <!-- 拖拽区:占满第二列(* 列自然延伸到右侧,系统按钮区由系统自己接管)。
                 SetTitleBar 的目标 —— 拖动 / 双击最大化由系统接管。Background 透明 → 透出云母。
                 图标与文本是非交互元素,不挡拖拽。 -->
            <Grid x:Name="AppTitleDragRegion"
                  Grid.Column="1"
                  Background="Transparent">
                <StackPanel Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0">
                    <Image x:Name="TitleBarIcon" Width="20" Height="20"
                           VerticalAlignment="Center"/>
                    <TextBlock x:Name="AppTitleText" Text="Reframe"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Row 1:NavigationView。自带汉堡隐藏(IsPaneToggleButtonVisible=False),改由 Row0 自绘汉堡驱动。
             已无浮层撞车问题,故 IsTitleBarAutoPaddingEnabled 与 NavigationViewButtonHolderGridMargin 资源全部清掉。
             OpenPaneLength=210、行高 48、图标 20px 保留。 -->
        <muxc:NavigationView
            x:Name="Nav"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            IsPaneToggleButtonVisible="False"
            OpenPaneLength="210"
            SelectionChanged="Nav_SelectionChanged">

            <!-- 导航项行高:默认 40 偏挤,提到 48 让图标(已放大到 20px)与文字更舒展,
                 对标成熟应用(图吧工具箱)的标准 NavigationView 观感(经 44/48 截图比对,48 更贴近其舒展度)。
                 OpenPaneLength 同步 200→210 平衡更大的行高。 -->
            <muxc:NavigationView.Resources>
                <x:Double x:Key="NavigationViewItemOnLeftMinHeight">48</x:Double>
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="仪表盘" Tag="dashboard">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F4;" FontSize="20"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="配置文件" Tag="profiles">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C1;" FontSize="20"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="布局" Tag="layouts">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80A;" FontSize="20"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="设置" Tag="settings">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="20"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </muxc:NavigationView>
    </Grid>
</Window>
